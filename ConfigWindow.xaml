<Window x:Class="WINHOME.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ConfigWindow"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#161820">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#B0C4FF" />
                                <Setter TargetName="bd" Property="BorderThickness" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Background="#6F6F6F" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#6F6F6F" CornerRadius="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1A1C24" Offset="0"/>
                <GradientStop Color="#0F1117" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Size settings removed; always full screen -->
        <DockPanel Grid.Row="0" Margin="12,10" LastChildFill="False">
            <TextBlock Text="当前使用全屏尺寸" Foreground="#EAEAEA" VerticalAlignment="Center"/>
        </DockPanel>

        <ScrollViewer
            Grid.Row="1"
            x:Name="GroupsScrollViewer"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            Padding="12,8,12,12">

            <ItemsControl x:Name="GroupsControl">

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <StackPanel>

                            <!-- Group header -->
                            <TextBlock
                                Text="{Binding Key}"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#EAEAEA"
                                Margin="12,12,12,6"/>

                            <!-- Tiles -->
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <!-- MUST match tile size -->
                                        <WrapPanel
                                            Orientation="Horizontal"
                                            ItemWidth="100"
                                            ItemHeight="100"
                                            HorizontalAlignment="Left"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Border Style="{StaticResource ConfigTileShellStyle}">
                                            <Grid MouseLeftButtonUp="AppTile_MouseLeftButtonUp">

                                                <Grid.ToolTip>
                                                    <ToolTip
                                                        Placement="Mouse"
                                                        ToolTipService.ShowDuration="60000"
                                                        ToolTipService.InitialShowDelay="150"
                                                        Background="#2B2E39"
                                                        Foreground="White"
                                                        Padding="8"
                                                        HasDropShadow="True">
                                                        <TextBlock Text="{Binding Name}"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="None"
                                                                   MaxWidth="360"
                                                                   FontSize="13"/>
                                                    </ToolTip>
                                                </Grid.ToolTip>

                                                <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource AppTileContent}" />

                                                <!-- pinned badge -->
                                                <Border
                                                    Background="#214A78"
                                                    CornerRadius="4"
                                                    Padding="4,2"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="已添加" FontSize="10" Foreground="White"/>
                                                </Border>

                                                <Grid.ContextMenu>
                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                        <MenuItem Header="添加到主界面" Click="AddToMain_Click" Tag="{Binding}"/>
                                                        <MenuItem Header="从主界面移除" Click="RemoveFromMain_Click" Tag="{Binding}"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>

                                            </Grid>
                                        </Border>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </ScrollViewer>

        <!-- Bubble -->
        <Border
            x:Name="Bubble"
            Background="#555555"
            CornerRadius="10"
            Padding="10"
            Visibility="Collapsed"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Margin="0,0,12,0">

            <TextBlock
                x:Name="BubbleText"
                FontSize="24"
                FontWeight="Bold"
                Foreground="White"/>
        </Border>

        <Border Grid.RowSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,12,10"
                Padding="12,8,12,8"
                CornerRadius="12"
                Background="#2A2E39"
                BorderBrush="#3D4252"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="WINHOOME"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#E6E8EF"
                           HorizontalAlignment="Right"
                           Margin="0,0,2,6"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ConfigPinButton"
                            Style="{StaticResource IconButtonStyle}"
                            Click="ConfigPinButton_Click"
                            Margin="0,0,8,0"
                            ToolTip="固定窗口">
                        <Grid>
                            <Ellipse Fill="Transparent" x:Name="ConfigPinBg" />
                            <TextBlock FontSize="18"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center">📌</TextBlock>
                        </Grid>
                    </Button>
                    <Button x:Name="BackToMainButton"
                            Style="{StaticResource IconButtonStyle}"
                            Click="BackToMainButton_Click"
                            ToolTip="返回主界面">
                        <TextBlock FontSize="18" Foreground="#FFFFFF">🏠</TextBlock>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</Window>
