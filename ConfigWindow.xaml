<Window x:Class="WINHOME.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ConfigWindow"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#161820">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#B0C4FF" />
                                <Setter TargetName="bd" Property="BorderThickness" Value="1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Background="#6F6F6F" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#6F6F6F" CornerRadius="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Geometry x:Key="IconMinusGeometry">M2,8 L14,8</Geometry>
        <Geometry x:Key="IconPlusGeometry">M2,8 L14,8 M8,2 L8,14</Geometry>

        <Style x:Key="DockBarStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,8,12,8"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="#D92A2E39"/>
            <Setter Property="BorderBrush" Value="#8593A8"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12"
                                      ShadowDepth="0"
                                      Opacity="0.38"
                                      Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
                <Border x:Name="ConfigOuterFrame"
                Margin="0"
                CornerRadius="14"
                Background="#66141A23"
                BorderBrush="#85AFC6D9"
                BorderThickness="1.2"
                SnapsToDevicePixels="True"
                IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect BlurRadius="26"
                                  ShadowDepth="0"
                                  Opacity="0.45"
                                  Color="#000000"/>
            </Border.Effect>
        </Border>
        <Border Margin="1"
                CornerRadius="13"
                Background="#12FFFFFF"
                BorderBrush="#2EFFFFFF"
                BorderThickness="1"
                IsHitTestVisible="False"/>
                <Grid x:Name="ConfigRoot"
              Margin="9">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="2"
                    CornerRadius="14"
                    Background="#C51A1C24"
                    BorderBrush="#2EFFFFFF"
                    BorderThickness="1"
                    IsHitTestVisible="False"/>

            <Border Grid.RowSpan="2"
                    CornerRadius="14"
                    Background="#0AFFFFFF"
                    IsHitTestVisible="False"/>

            <Grid x:Name="ConfigContentHost"
              Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Windowed layout is applied automatically from launcher settings -->
            <DockPanel Grid.Row="0" Margin="12,10" LastChildFill="False">
                <TextBlock Text="当前使用窗口化大尺寸布局" Foreground="#EAEAEA" VerticalAlignment="Center"/>
            </DockPanel>

            <ScrollViewer
                Grid.Row="1"
                x:Name="GroupsScrollViewer"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                Padding="8,8,8,8">
                <StackPanel>


                <Border
                    Margin="0,0,0,8"
                    Padding="10,8"
                    Background="#1B2431"
                    BorderBrush="#3A4A5E"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="最新扫描到的应用"
                                   Foreground="#EAEAEA"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>

                        <ItemsControl Grid.Row="1"
                                      Margin="0,8,0,0"
                                      ItemsSource="{Binding LatestScannedApps, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel
                                        Orientation="Horizontal"
                                        ItemWidth="{Binding ConfigTileSlotSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ItemHeight="{Binding ConfigTileSlotSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                        HorizontalAlignment="Left"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ConfigTileShellStyle}">
                                        <Border.LayoutTransform>
                                            <ScaleTransform ScaleX="{Binding ConfigTileScale, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            ScaleY="{Binding ConfigTileScale, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </Border.LayoutTransform>
                                        <Grid MouseLeftButtonUp="AppTile_MouseLeftButtonUp">

                                            <Grid.ToolTip>
                                                <ToolTip
                                                    Placement="Mouse"
                                                    ToolTipService.ShowDuration="60000"
                                                    ToolTipService.InitialShowDelay="150"
                                                    Background="#2B2E39"
                                                    Foreground="White"
                                                    Padding="8"
                                                    HasDropShadow="True">
                                                    <TextBlock Text="{Binding Name}"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="None"
                                                               MaxWidth="360"
                                                               FontSize="13"/>
                                                </ToolTip>
                                            </Grid.ToolTip>

                                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource AppTileContent}" />

                                            <Border
                                                Background="#214A78"
                                                CornerRadius="4"
                                                Padding="4,2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="已添加" FontSize="10" Foreground="White"/>
                                            </Border>

                                            <Border
                                                Background="#214A78"
                                                CornerRadius="4"
                                                Padding="4,2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Margin="0,0,2,2"
                                                Visibility="{Binding IsInvalid, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="已失效" FontSize="10" Foreground="White"/>
                                            </Border>

                                            <Grid.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem Header="添加到主界面" Click="AddToMain_Click" Tag="{Binding}"/>
                                                    <MenuItem Header="从主界面移除" Click="RemoveFromMain_Click" Tag="{Binding}"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
                <ItemsControl x:Name="GroupsControl">

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <StackPanel>

                            <!-- Group header -->
                            <TextBlock
                                Text="{Binding Key}"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#EAEAEA"
                                Margin="2,2,2,2"/>

                            <!-- Tiles -->
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <!-- MUST match tile size -->
                                        <WrapPanel
                                            Orientation="Horizontal"
                                            ItemWidth="{Binding ConfigTileSlotSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                            ItemHeight="{Binding ConfigTileSlotSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                            HorizontalAlignment="Left"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <Border Style="{StaticResource ConfigTileShellStyle}">
                                            <Border.LayoutTransform>
                                                <ScaleTransform ScaleX="{Binding ConfigTileScale, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                ScaleY="{Binding ConfigTileScale, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                            </Border.LayoutTransform>
                                            <Grid MouseLeftButtonUp="AppTile_MouseLeftButtonUp">

                                                <Grid.ToolTip>
                                                    <ToolTip
                                                        Placement="Mouse"
                                                        ToolTipService.ShowDuration="60000"
                                                        ToolTipService.InitialShowDelay="150"
                                                        Background="#2B2E39"
                                                        Foreground="White"
                                                        Padding="8"
                                                        HasDropShadow="True">
                                                        <TextBlock Text="{Binding Name}"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="None"
                                                                   MaxWidth="360"
                                                                   FontSize="13"/>
                                                    </ToolTip>
                                                </Grid.ToolTip>

                                                <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource AppTileContent}" />

                                                <!-- pinned badge -->
                                                <Border
                                                    Background="#214A78"
                                                    CornerRadius="4"
                                                    Padding="4,2"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="已添加" FontSize="10" Foreground="White"/>
                                                </Border>
                                                <Border
                                                    Background="#214A78"
                                                    CornerRadius="4"
                                                    Padding="4,2"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom"
                                                    Margin="0,0,2,2"
                                                    Visibility="{Binding IsInvalid, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="已失效" FontSize="10" Foreground="White"/>
                                                </Border>

                                                <Grid.ContextMenu>
                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                        <MenuItem Header="添加到主界面" Click="AddToMain_Click" Tag="{Binding}"/>
                                                        <MenuItem Header="从主界面移除" Click="RemoveFromMain_Click" Tag="{Binding}"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>

                                            </Grid>
                                        </Border>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

                </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- Bubble -->
            <Border
                x:Name="Bubble"
                Background="#555555"
                CornerRadius="10"
                Padding="10"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,12,0">

                <TextBlock
                    x:Name="BubbleText"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="White"/>
            </Border>
        </Grid>

        <Border x:Name="ConfigDockBar"
                Style="{StaticResource DockBarStyle}"
                Grid.RowSpan="2"
                Panel.ZIndex="1000"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,12,10"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,8,0">
                    <Button x:Name="ConfigZoomOutButton"
                            Style="{StaticResource IconButtonStyle}"
                            Click="ConfigZoomOutButton_Click"
                            ToolTip="整体缩小">
                        <Viewbox Width="18" Height="18" Stretch="Uniform">
                            <Path Data="{StaticResource IconMinusGeometry}"
                                  Stroke="#FFFFFF"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  SnapsToDevicePixels="True"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="ConfigZoomInButton"
                            Style="{StaticResource IconButtonStyle}"
                            Click="ConfigZoomInButton_Click"
                            Margin="0,6,0,0"
                            ToolTip="整体放大">
                        <Viewbox Width="18" Height="18" Stretch="Uniform">
                            <Path Data="{StaticResource IconPlusGeometry}"
                                  Stroke="#FFFFFF"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  SnapsToDevicePixels="True"/>
                        </Viewbox>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="0,0,10,0">
                    <Button x:Name="BackToMainButton"
                            Style="{StaticResource IconButtonStyle}"
                            Click="BackToMainButton_Click"
                            ToolTip="返回主界面">
                        <Path Fill="#FFFFFF"
                              Stretch="Uniform"
                              Width="20"
                              Height="20"
                              Data="M22,6 L36,18 L36,34 L28,34 L28,24 L16,24 L16,34 L8,34 L8,18 Z"/>
                    </Button>
                    <Button x:Name="ConfigPinButton"
                            Style="{StaticResource IconButtonStyle}"
                            Click="ConfigPinButton_Click"
                            Margin="0,6,0,0"
                            ToolTip="固定窗口">
                        <Grid>
                            <Ellipse Fill="Transparent" x:Name="ConfigPinBg" />
                            <TextBlock FontSize="18"
                                       Foreground="#FFFFFF"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center">📌</TextBlock>
                        </Grid>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Vertical"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="WIN"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#E6E8EF"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="HOME"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#E6E8EF"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
    </Grid>
</Window>

