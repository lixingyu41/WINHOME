<Window x:Class="WINHOME.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ConfigWindow"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#161820">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Background="#6F6F6F" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#6F6F6F" CornerRadius="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1A1C24" Offset="0"/>
                <GradientStop Color="#0F1117" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Size settings -->
        <DockPanel Grid.Row="0" Margin="12,10" LastChildFill="False">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="宽度%" Foreground="#EAEAEA" VerticalAlignment="Center"/>
                <TextBox x:Name="WidthPercentBox" Width="30" Margin="6,0" VerticalAlignment="Center" />
                <TextBlock Text="高度%" Foreground="#EAEAEA" VerticalAlignment="Center" Margin="12,0,0,0"/>
                <TextBox x:Name="HeightPercentBox" Width="30" Margin="6,0" VerticalAlignment="Center" />
                <Button Content="应用" Width="72" Margin="12,0,0,0" Click="ApplySizeButton_Click"/>
            </StackPanel>
        </DockPanel>

        <ScrollViewer
            Grid.Row="1"
            x:Name="GroupsScrollViewer"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            Padding="12,8,12,12">

            <ItemsControl x:Name="GroupsControl">

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <StackPanel>

                            <!-- Group header -->
                            <TextBlock
                                Text="{Binding Key}"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#EAEAEA"
                                Margin="12,12,12,6"/>

                            <!-- Tiles -->
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <!-- MUST match tile size -->
                                        <WrapPanel
                                            Orientation="Horizontal"
                                            ItemWidth="118"
                                            ItemHeight="140"
                                            HorizontalAlignment="Left"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                            <Border
                                                Width="112"
                                            Height="132"
                                            Margin="3"
                                            Padding="0"
                                            CornerRadius="10">

                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#2B2E39"/>
                                                    <Setter Property="BorderBrush" Value="#3A3E4D"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="8" Color="#66000000" ShadowDepth="2" Opacity="0.25"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                            <Setter Property="Background" Value="#35507A"/>
                                                            <Setter Property="BorderBrush" Value="#6CA0FF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid
                                                MouseLeftButtonUp="AppTile_MouseLeftButtonUp">

                                                <Grid.ToolTip>
                                                    <ToolTip
                                                        Placement="Mouse"
                                                        ToolTipService.ShowDuration="60000"
                                                        ToolTipService.InitialShowDelay="150"
                                                        Background="#2B2E39"
                                                        Foreground="White"
                                                        Padding="8"
                                                        HasDropShadow="True">
                                                        <TextBlock Text="{Binding Name}"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="None"
                                                                   MaxWidth="360"
                                                                   FontSize="13"/>
                                                    </ToolTip>
                                                </Grid.ToolTip>

                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <!-- Icon -->
                                                <Image
                                                    Source="{Binding Icon}"
                                                    Width="95"
                                                    Height="95"
                                                    Margin="6"
                                                    HorizontalAlignment="Center"
                                                    Stretch="Uniform"/>

                                                <!-- App name -->
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Text="{Binding Name}"
                                                    FontSize="12"
                                                    LineHeight="18"
                                                    MaxHeight="36"
                                                    Margin="0,2,0,0"
                                                    TextWrapping="Wrap"
                                                    TextAlignment="Center"
                                                    Foreground="White"
                                                    TextTrimming="CharacterEllipsis"/>

                                                <!-- pinned badge -->
                                                <Border
                                                    Grid.Row="0"
                                                    Background="#214A78"
                                                    CornerRadius="4"
                                                    Padding="4,2"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="已添加" FontSize="10" Foreground="White"/>
                                                </Border>

                                                <Grid.ContextMenu>
                                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                        <MenuItem Header="添加到主界面" Click="AddToMain_Click" Tag="{Binding}"/>
                                                        <MenuItem Header="从主界面移除" Click="RemoveFromMain_Click" Tag="{Binding}"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>

                                            </Grid>
                                        </Border>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </ScrollViewer>

        <!-- Bubble -->
        <Border
            x:Name="Bubble"
            Background="#555555"
            CornerRadius="10"
            Padding="10"
            Visibility="Collapsed"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Margin="0,0,12,0">

            <TextBlock
                x:Name="BubbleText"
                FontSize="24"
                FontWeight="Bold"
                Foreground="White"/>
        </Border>

    </Grid>
</Window>
